Project MyBro_Core_Chatbot {
  database_type: 'PostgreSQL'
  Note: 'Operational chatbot database. The separate Schema Studio stores only its own app data in PostgreSQL.'
}

Table organizations {
  id uuid [pk, default: `gen_random_uuid()`]
  slug varchar(80) [not null, unique]
  name varchar(160) [not null]
  data_policy jsonb [not null, default: `'{}'::jsonb`]
  retention_days int [not null, default: 365]
  region varchar(32) [not null]
  status varchar(24) [not null, default: 'active']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table users {
  id uuid [pk, default: `gen_random_uuid()`]
  external_subject varchar(255) [unique]
  email varchar(254)
  display_name varchar(160) [not null]
  profile_metadata jsonb [not null, default: `'{}'::jsonb`]
  status varchar(24) [not null, default: 'active']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table memberships {
  organization_id uuid [not null, ref: > organizations.id]
  user_id uuid [not null, ref: > users.id]
  role varchar(40) [not null]
  status varchar(24) [not null, default: 'active']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (organization_id, user_id) [pk]
    (organization_id, role)
  }
}

Table model_endpoints {
  id uuid [pk, default: `gen_random_uuid()`]
  organization_id uuid [not null, ref: > organizations.id]
  name varchar(120) [not null]
  provider varchar(60) [not null]
  endpoint_kind varchar(24) [not null, note: 'chat or embedding']
  model_name varchar(160) [not null]
  endpoint_metadata jsonb [not null, default: `'{}'::jsonb`]
  secret_ref varchar(255) [not null, note: 'Reference to Secrets Manager; never the secret value']
  approved boolean [not null, default: false]
  status varchar(24) [not null, default: 'active']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (organization_id, name) [unique]
    (organization_id, endpoint_kind, approved)
  }
}

Table bots {
  id uuid [pk, default: `gen_random_uuid()`]
  organization_id uuid [not null, ref: > organizations.id]
  name varchar(120) [not null]
  use_case varchar(40) [not null, note: 'customer, employee, or domain']
  status varchar(24) [not null, default: 'draft']
  created_by uuid [not null, ref: > users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (organization_id, name) [unique]
    (organization_id, status)
  }
}

Table bot_versions {
  id uuid [pk, default: `gen_random_uuid()`]
  bot_id uuid [not null, ref: > bots.id]
  version_number int [not null]
  prompt_template text [not null]
  policy_config jsonb [not null, default: `'{}'::jsonb`]
  model_endpoint_id uuid [not null, ref: > model_endpoints.id]
  embedding_endpoint_id uuid [ref: > model_endpoints.id]
  published_by uuid [ref: > users.id]
  published_at timestamptz
  created_by uuid [not null, ref: > users.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (bot_id, version_number) [unique]
    (bot_id, published_at)
  }
}

Table conversations {
  id uuid [pk, default: `gen_random_uuid()`]
  organization_id uuid [not null, ref: > organizations.id]
  bot_id uuid [not null, ref: > bots.id]
  user_id uuid [ref: > users.id]
  anonymous_session_subject varchar(255)
  status varchar(24) [not null, default: 'active']
  started_at timestamptz [not null, default: `now()`]
  last_message_at timestamptz [not null, default: `now()`]
  closed_at timestamptz

  indexes {
    (organization_id, user_id, last_message_at)
    (organization_id, bot_id, status)
  }
}

Table messages {
  id uuid [pk, default: `gen_random_uuid()`]
  organization_id uuid [not null, ref: > organizations.id]
  conversation_id uuid [not null, ref: > conversations.id]
  role varchar(24) [not null, note: 'user, assistant, tool, or system']
  content_ciphertext text [note: 'Protected inline content when approved']
  content_ref varchar(500) [note: 'Approved external content reference']
  safety_status varchar(32) [not null, default: 'unchecked']
  model_endpoint_id uuid [ref: > model_endpoints.id]
  prompt_tokens int [not null, default: 0]
  completion_tokens int [not null, default: 0]
  cost_amount numeric(14,6) [not null, default: 0]
  latency_ms int
  trace_id uuid [not null]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (conversation_id, created_at)
    (organization_id, trace_id)
  }
}

Table feedback {
  id uuid [pk, default: `gen_random_uuid()`]
  message_id uuid [not null, ref: > messages.id]
  user_id uuid [ref: > users.id]
  rating smallint [not null, note: '-1 or 1']
  reason varchar(80)
  comment text
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (message_id, user_id) [unique]
  }
}

Table handoffs {
  id uuid [pk, default: `gen_random_uuid()`]
  conversation_id uuid [not null, unique, ref: > conversations.id]
  requested_by uuid [ref: > users.id]
  reason text [not null]
  target_queue varchar(120) [not null]
  external_ticket_ref varchar(255)
  status varchar(24) [not null, default: 'requested']
  requested_at timestamptz [not null, default: `now()`]
  resolved_at timestamptz
}

Table integrations {
  id uuid [pk, default: `gen_random_uuid()`]
  organization_id uuid [not null, ref: > organizations.id]
  bot_id uuid [ref: > bots.id]
  integration_type varchar(40) [not null, note: 'CRM, HRIS, ITSM, DMS, or domain system']
  name varchar(120) [not null]
  endpoint_metadata jsonb [not null, default: `'{}'::jsonb`]
  secret_ref varchar(255) [not null]
  allowed_operations jsonb [not null, default: `'[]'::jsonb`]
  status varchar(24) [not null, default: 'active']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (organization_id, name) [unique]
    (organization_id, integration_type, status)
  }
}

Table knowledge_sources {
  id uuid [pk, default: `gen_random_uuid()`]
  organization_id uuid [not null, ref: > organizations.id]
  bot_id uuid [ref: > bots.id]
  integration_id uuid [ref: > integrations.id]
  name varchar(160) [not null]
  source_type varchar(40) [not null]
  owner_user_id uuid [not null, ref: > users.id]
  classification varchar(40) [not null]
  sync_status varchar(24) [not null, default: 'pending']
  last_synced_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (organization_id, name) [unique]
    (organization_id, bot_id, sync_status)
  }
}

Table documents {
  id uuid [pk, default: `gen_random_uuid()`]
  knowledge_source_id uuid [not null, ref: > knowledge_sources.id]
  external_key varchar(500) [not null]
  title varchar(500) [not null]
  source_version varchar(120) [not null]
  mime_type varchar(120) [not null]
  object_ref varchar(1000) [not null]
  classification varchar(40) [not null]
  checksum_sha256 char(64) [not null]
  processing_status varchar(24) [not null, default: 'pending']
  source_updated_at timestamptz
  processed_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (knowledge_source_id, external_key, source_version) [unique]
    (knowledge_source_id, processing_status)
  }
}

Table document_acl_entries {
  id uuid [pk, default: `gen_random_uuid()`]
  document_id uuid [not null, ref: > documents.id]
  principal_type varchar(24) [not null, note: 'user, role, group, or public']
  principal_ref varchar(255) [not null]
  permission varchar(24) [not null, default: 'read']
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (document_id, principal_type, principal_ref, permission) [unique]
    (principal_type, principal_ref)
  }
}

Table document_chunks {
  id uuid [pk, default: `gen_random_uuid()`]
  document_id uuid [not null, ref: > documents.id]
  chunk_index int [not null]
  content_text text [not null]
  embedding vector(1536) [not null]
  token_count int [not null]
  page_number int
  section_title varchar(500)
  metadata jsonb [not null, default: `'{}'::jsonb`]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (document_id, chunk_index) [unique]
  }
}

Table citations {
  message_id uuid [not null, ref: > messages.id]
  document_chunk_id uuid [not null, ref: > document_chunks.id]
  ordinal smallint [not null]
  quote_excerpt text
  source_location varchar(500) [not null]

  indexes {
    (message_id, ordinal) [pk]
    (document_chunk_id)
  }
}

Table tool_executions {
  id uuid [pk, default: `gen_random_uuid()`]
  message_id uuid [not null, ref: > messages.id]
  integration_id uuid [not null, ref: > integrations.id]
  operation varchar(120) [not null]
  sanitized_input jsonb [not null]
  sanitized_output jsonb
  status varchar(24) [not null, default: 'pending']
  approval_required boolean [not null, default: false]
  approved_by uuid [ref: > users.id]
  approval_reference varchar(255)
  started_at timestamptz [not null, default: `now()`]
  completed_at timestamptz

  indexes {
    (message_id, started_at)
    (integration_id, status, started_at)
  }
}

Table audit_events {
  id uuid [pk, default: `gen_random_uuid()`]
  organization_id uuid [not null, ref: > organizations.id]
  actor_user_id uuid [ref: > users.id]
  action varchar(120) [not null]
  resource_type varchar(80) [not null]
  resource_id varchar(255) [not null]
  result varchar(24) [not null]
  policy_version varchar(80)
  trace_id uuid [not null]
  metadata jsonb [not null, default: `'{}'::jsonb`]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (organization_id, created_at)
    (organization_id, trace_id)
    (resource_type, resource_id, created_at)
  }
}

Table usage_events {
  id uuid [pk, default: `gen_random_uuid()`]
  organization_id uuid [not null, ref: > organizations.id]
  message_id uuid [not null, ref: > messages.id]
  model_endpoint_id uuid [not null, ref: > model_endpoints.id]
  prompt_tokens int [not null, default: 0]
  completion_tokens int [not null, default: 0]
  cost_amount numeric(14,6) [not null, default: 0]
  latency_ms int [not null]
  provider_request_id varchar(255)
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (organization_id, created_at)
    (message_id)
    (model_endpoint_id, created_at)
  }
}

Table evaluation_cases {
  id uuid [pk, default: `gen_random_uuid()`]
  organization_id uuid [not null, ref: > organizations.id]
  bot_id uuid [ref: > bots.id]
  name varchar(160) [not null]
  question text [not null]
  expected_evidence jsonb [not null, default: `'[]'::jsonb`]
  expected_behavior text [not null]
  category varchar(60) [not null]
  risk_level varchar(24) [not null]
  active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (organization_id, bot_id, active)
  }
}

Table evaluation_runs {
  id uuid [pk, default: `gen_random_uuid()`]
  bot_version_id uuid [not null, ref: > bot_versions.id]
  model_endpoint_id uuid [not null, ref: > model_endpoints.id]
  release_reference varchar(255)
  status varchar(24) [not null, default: 'running']
  aggregate_score numeric(6,3)
  started_at timestamptz [not null, default: `now()`]
  completed_at timestamptz
  created_by uuid [not null, ref: > users.id]

  indexes {
    (bot_version_id, started_at)
    (release_reference)
  }
}

Table evaluation_results {
  evaluation_run_id uuid [not null, ref: > evaluation_runs.id]
  evaluation_case_id uuid [not null, ref: > evaluation_cases.id]
  status varchar(24) [not null]
  score numeric(6,3)
  actual_answer_ref varchar(500)
  evidence_result jsonb [not null, default: `'{}'::jsonb`]
  details jsonb [not null, default: `'{}'::jsonb`]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (evaluation_run_id, evaluation_case_id) [pk]
    (evaluation_case_id, created_at)
  }
}
